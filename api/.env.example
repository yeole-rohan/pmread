# Auth
JWT_SECRET=<generate: openssl rand -hex 32>

# Database (local PostgreSQL)
DATABASE_URL=postgresql://pmread_user:password@localhost/pmread

# Claude (paid — required)
ANTHROPIC_API_KEY=sk-ant-...

# Email (SMTP — your domain mail server, free)
# Port 587 = STARTTLS (SMTP_TLS=true), Port 465 = SSL only (SMTP_TLS=false)
# Leave SMTP_HOST empty to skip sending emails in dev (link printed to console)
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=587
SMTP_USER=hello@yourdomain.com
SMTP_PASSWORD=
SMTP_TLS=true
EMAIL_FROM=hello@yourdomain.com
EMAIL_FROM_NAME=PMRead

# Stripe (paid — required for billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...

# Razorpay (India billing — optional)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=
RAZORPAY_PRO_PLAN_ID=plan_...

# App
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000

# Sentry (free tier — optional)
SENTRY_DSN=

# Storage
EXPORTS_DIR=./exports
